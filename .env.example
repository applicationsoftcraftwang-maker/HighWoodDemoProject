# === App ===
NODE_ENV=development
PORT=3000

# === Postgres (docker-compose) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=emissions
POSTGRES_USER=emissions
POSTGRES_PASSWORD=emissions
DATABASE_URL=postgresql://emissions:emissions@localhost:5432/emissions

# Backend (FastAPI) — populated in commit 2
RUN_MIGRATIONS=true
FRONTEND_URL=http://localhost:5173

# Frontend (Vite) — populated in commit 12
VITE_API_URL=http://localhost:8000/api/v1ß

# === pgAdmin (optional, only if running with --profile tools) ===
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050